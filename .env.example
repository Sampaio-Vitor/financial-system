# Database
DATABASE_URL=mysql+aiomysql://portfolio_user:portfolio_pass@localhost:3306/portfolio

# JWT
SECRET_KEY=<GENERATE_WITH_openssl_rand_-hex_32>
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Admin user (for seed script)
ADMIN_USERNAME=<YOUR_ADMIN_USERNAME>
ADMIN_PASSWORD=<YOUR_ADMIN_PASSWORD>

# Cloudflare Turnstile (leave empty to disable in dev)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
