# Database
DATABASE_URL=mysql+aiomysql://portfolio_user:portfolio_pass@localhost:3306/portfolio

# JWT
SECRET_KEY=<GENERATE_WITH_openssl_rand_-hex_32>
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
REFRESH_TOKEN_EXPIRATION_DAYS=30

# Admin user (for seed script)
ADMIN_USERNAME=<YOUR_ADMIN_USERNAME>
ADMIN_PASSWORD=<YOUR_ADMIN_PASSWORD>

# Cloudflare Turnstile (leave empty to disable in dev)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_REQUIRED=false

# Encryption (for Pluggy credentials — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Session cookies
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=strict
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# API docs
API_DOCS_ENABLED=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
